# ============================================
# CrewCmd — Environment Configuration
# ============================================
# Copy this to .env.local and fill in your values.
#
# For Docker: docker compose reads this file directly.
# For local dev: leave DATABASE_URL empty to use PGlite (zero-config).

# ── Database ─────────────────────────────────────────────────────
# Neon, Supabase, or any Postgres. Leave empty for PGlite local dev.
# Docker Compose sets this automatically — no need to change.
# DATABASE_URL="postgresql://user:password@host:5432/crewcmd?sslmode=require"

# Docker Compose Postgres password (only used by docker-compose.yml)
POSTGRES_PASSWORD="crewcmd"

# ── Auth ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Optional: GitHub OAuth
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Storage ──────────────────────────────────────────────────────
# Vercel Blob (for task images, agent avatars). Optional.
BLOB_READ_WRITE_TOKEN=""

# ── API Auth ─────────────────────────────────────────────────────
# Bearer token for agent heartbeats and API mutations
# Generate: openssl rand -hex 32
HEARTBEAT_SECRET=""

# ── Integrations (Optional) ─────────────────────────────────────

# OpenClaw gateway for agent orchestration
# OPENCLAW_GATEWAY_URL="http://localhost:18789"

# Slack notifications
# SLACK_BOT_TOKEN="xoxb-..."
# SLACK_NOTIFICATION_CHANNEL="U..."

# Default human assignee for escalated tasks
# DEFAULT_HUMAN_ASSIGNEE="admin"

# GitHub webhook for PR tracking
# GITHUB_WEBHOOK_SECRET=""

# ── Docker Compose Overrides ────────────────────────────────────
# APP_PORT=3000
# POSTGRES_PORT=5432
