# ============================================
# CrewCmd — Environment Configuration
# ============================================
# Copy this to .env.local and fill in your values.
#
# Leave DATABASE_URL empty for zero-config local dev (uses PGlite).
# Set it for production or to use an external Postgres.

# Database (Neon serverless Postgres, or any Postgres)
# DATABASE_URL="postgresql://user:password@your-host.neon.tech/crewcmd?sslmode=require"

# Auth.js (NextAuth v5)
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob Storage (for task images, agent avatars)
BLOB_READ_WRITE_TOKEN=""

# API Auth — Bearer token for agent heartbeats and API mutations
# Generate: openssl rand -hex 32
HEARTBEAT_SECRET=""

# Optional: OpenClaw integration
# OPENCLAW_GATEWAY_URL="http://localhost:18789"

# Optional: Slack notifications
# SLACK_BOT_TOKEN="xoxb-..."
# SLACK_NOTIFICATION_CHANNEL="U..."  # User or channel ID for task assignment notifications

# Optional: Default human assignee for escalated tasks
# DEFAULT_HUMAN_ASSIGNEE="admin"

# Optional: GitHub webhook for PR tracking
# Generate: openssl rand -hex 32
# GITHUB_WEBHOOK_SECRET=""
