meta {
  name: Update File
  type: http
  seq: 3
}

patch {
  url: {{base_url}}/api/workspace/file
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "path": "docs/example.md",
    "content": "# Updated Content\n\nNew markdown content."
  }
}

docs {
  Only .md files are allowed. Path must not start with /
  or contain .. (path traversal prevention).
}
